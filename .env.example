AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# Copy fresh temporary credentials from AWS Academy each lab session.
AWS_ACCESS_KEY_ID=PASTE_LAB_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=PASTE_LAB_SECRET_ACCESS_KEY
AWS_SESSION_TOKEN=PASTE_LAB_SESSION_TOKEN

# LLM config for issue generation and exam evaluation. API key lives in AWS Secrets Manager, never in .env.
LLM_SECRET_NAME=salesops/dev/llm-api-keys
OPENAI_MODEL=gpt-5.4-mini

# Copy to frontend/.env.local after the backend deploy prints the API URL.
VITE_API_BASE_URL=https://example.execute-api.us-east-1.amazonaws.com/dev
